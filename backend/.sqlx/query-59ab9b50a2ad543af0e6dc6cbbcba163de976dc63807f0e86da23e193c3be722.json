{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT w.id, w.name, w.color, w.updated_at, w.deleted_at\n        FROM workspace w\n        JOIN workspace_member m ON m.workspace_id = w.id\n        WHERE m.user_id = $1\n          AND ($2::timestamptz IS NULL OR w.updated_at > $2)\n        ",
