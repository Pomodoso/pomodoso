{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT t.id, t.title, t.status, t.completed_at, t.ticket_id, t.extra,\n               t.project_id,\n               p.name  as \"project_name?\",\n               p.color as \"project_color?\"\n        FROM task t\n        LEFT JOIN project p ON p.id = t.project_id\n        WHERE t.workspace_id = ANY($1)\n          AND t.deleted_at IS NULL\n        ",
