DATABASE_URL=postgres://postgres:postgres@localhost:5432/pomodoso
PORT=8080
FRONTEND_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_FOUNDER_LIFETIME_PRICE_ID=price_...

# Resend
RESEND_API_KEY=re_...
# Sender must be on a domain verified in Resend (https://resend.com/domains).
# For now we send from the already-verified otpilot.app domain until pomodoso.com
# is verified. (Resend's test-only sender onboarding@resend.dev also works locally
# but only delivers to your own Resend account email.)
RESEND_FROM_EMAIL=Pomodoso <noreply@otpilot.app>

# Sentry (error reporting) — leave blank to disable. From your Sentry project:
# Settings → Client Keys (DSN).
SENTRY_DSN=
# Fraction of transactions traced (0.0–1.0). Defaults to 0.2 (20%).
SENTRY_TRACES_SAMPLE_RATE=0.2
