    "@pomodoso/types": "workspace:*",
    "@pomodoso/ui": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.1.42",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^6.4.2"
