VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=https://api.pomodoso.com

# Support chat — Crisp → Settings → Website Settings → Setup ("Website ID")
VITE_CRISP_WEBSITE_ID=

# Error reporting — Sentry project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
# Fraction of transactions traced (0.0–1.0). Defaults to 0.2 (20%).
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# Analytics — Google Analytics 4 Measurement ID (Admin → Data Streams)
VITE_GA_ID=G-XXXXXXXXXX
